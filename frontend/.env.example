# Localhost mode (recommended)
# In dev, keep relative /api and let Vite proxy handle backend requests.
# Patient "remember this device" uses an httpOnly cookie: it must be same-site as the app
# (relative /api + proxy). Pointing VITE_API_BASE_URL at http://127.0.0.1:8000 from the
# Vite app on :5173 is a different origin — the cookie from Django may not be stored/sent.
VITE_API_BASE_URL=/api
VITE_PUBLIC_SITE_URL=http://localhost:5173

# Local network mode (phone testing on same Wi-Fi)
# Replace 192.168.x.x with your MacBook LAN IP.
# Example: VITE_API_BASE_URL=http://192.168.1.42:8000/api
# Example: VITE_PUBLIC_SITE_URL=http://192.168.1.42:5173
