DEBUG=True
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175,http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175,http://localhost:5173,http://127.0.0.1:5173
# Leave empty for local SQLite. Set for production PostgreSQL.
DATABASE_URL=

# Email backend (DEV default: console backend prints emails in backend logs)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@med-questionnaire.local
EMAIL_TIMEOUT=20

# Optional: shown in patient emails and as portal link (e.g. https://app.example.com).
# PATIENT_PORTAL_BASE_URL=http://localhost:5175
# EMAIL_SITE_BRAND_NAME=Med Questionnaire

# SMTP mode example:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password_here
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# DEFAULT_FROM_EMAIL=your_email@gmail.com

# OTP / email verification policy
VERIFICATION_CODE_TTL_SECONDS=600
VERIFICATION_CODE_MAX_ATTEMPTS=5
VERIFICATION_CODE_RESEND_COOLDOWN_SECONDS=60
# Rolling 1-hour window: counts EmailVerificationCode rows per email+purpose.
# In settings: if DEBUG and this env is unset, default is 100; in production, 5.
# For local dev, either rely on DEBUG (100) or set a high value. To clear history for one email:
#   python manage.py clear_verification_throttle you@example.com --purpose patient_login
VERIFICATION_CODE_MAX_REQUESTS_PER_HOUR=5

# Patient "remember this device" after OTP (httpOnly cookie + DB hash). Default 30 days.
# PATIENT_TRUSTED_DEVICE_MAX_AGE_SECONDS=2592000
# PATIENT_TRUSTED_DEVICE_COOKIE_NAME=mq_patient_td
# HTTPS production: PATIENT_TRUSTED_DEVICE_COOKIE_SECURE=true

# Local network mode (phone testing on same Wi-Fi)
# Replace 192.168.x.x with your MacBook LAN IP.
# ALLOWED_HOSTS=localhost,127.0.0.1,192.168.x.x
# CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175,http://192.168.x.x:5175
# CSRF_TRUSTED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175,http://192.168.x.x:5175
